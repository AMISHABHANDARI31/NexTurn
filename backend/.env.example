NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/nexturn
MONGO_DB_NAME=nexturn
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
JWT_SECRET=replace_with_at_least_64_random_characters
JWT_EXPIRES_IN=24h
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_brevo_smtp_login
EMAIL_PASSWORD=your_brevo_smtp_key
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_NAME=NexTurn
OTP_EXPIRES_IN_MINUTES=10
PASSWORD_RESET_EXPIRES_IN_MINUTES=15
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_RELAXED=true
LOG_LEVEL=info
BOOTSTRAP_ADMIN_NAME=NexTurn Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@nexturn.app
BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_strong_12_character_password
PYTHON_EXECUTABLE=python
